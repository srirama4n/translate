# API - MongoDB
MONGODB_URI=mongodb://localhost:27017
DATABASE_NAME=translate

# Run without MongoDB (uses in-memory mock with demo data)
# USE_MOCK_DB=true

# API - Server
API_HOST=0.0.0.0
API_PORT=8000

# Optional: Use in-memory mock DB when MongoDB is unavailable
# USE_MOCK_DB=true

# UI - API base URL (in ui/.env for Vite)
# VITE_API_URL=http://localhost:8000
